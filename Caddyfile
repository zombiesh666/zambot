zambot.live {
    # 👉 1. Write access logs to the shared volume
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # 👉 2. Route the GoAccess real-time WebSocket
    handle /ws-metrics* {
        reverse_proxy goaccess:7890
    }

    # 👉 3. Route all standard web traffic to FastAPI
    handle {
        reverse_proxy web:8000
    }
}
