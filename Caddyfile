zambot.live {
    # Standard log configuration
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # 👉 Create a named matcher for your internal noise endpoints
    @internal_noise path /metrics* /ws-metrics* /sync* /sessions* /wp-admin/install.php?step=1 /sitemap.xml /robots.txt /favicon.svg

    # 👉 Tell Caddy to completely bypass logging for these paths
    log_skip @internal_noise

    # Route the GoAccess real-time WebSocket
    handle /ws-metrics* {
        reverse_proxy goaccess:7890
    }

    # Route all standard web traffic to FastAPI
    handle {
        reverse_proxy web:8000
    }
}