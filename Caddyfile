# 👉 1. Explicitly catch all unencrypted HTTP traffic
http://zambot.live {
    # Perform the permanent secure redirect
    redir https://zambot.live{uri} permanent
    
    # Completely drop logging for this block so it never touches access.log
    log_skip
}

# 👉 2. Your production secure HTTPS block
zambot.live {
    # Standard log configuration (only captures secure traffic)
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # Match anything that is NOT a core user-facing route
    @not_user_traffic {
        not path /
    }
    log_skip @not_user_traffic

    # Match the DigitalOcean Uptime Probe by its User-Agent header
    @do_probe {
        header User-Agent *DigitalOcean*
    }
    log_skip @do_probe

    # Natively rewrite root favicon requests to the static file location
    rewrite /favicon.svg /static/favicon.svg
    rewrite /favicon.ico /static/favicon.svg

    # Route the GoAccess real-time WebSocket
    handle /ws-metrics* {
        reverse_proxy goaccess:7890
    }

    # Route all standard web traffic to FastAPI
    handle {
        reverse_proxy web:8000
    }
}
