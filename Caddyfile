zambot.live {
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # 👉 Pass the WebSocket upgrade headers explicitly
    handle /ws-metrics* {
        reverse_proxy goaccess:7890 {
            header_up Upgrade {>Upgrade}
            header_up Connection {>Connection}
            header_up Host {host}
        }
    }

    handle {
        reverse_proxy web:8000
    }
}
