zambot.live {
    # Standard log configuration
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # 👉 Expanded noise matcher to filter out bot scanners, system routing, and static SEO files
    @internal_noise path /metrics* /ws-metrics* /sessions* /wp-admin* /.well-known* /sync* /sitemap.xml /robots.txt /favicon.svg
    log_skip @internal_noise

    # Natively rewrite root favicon requests to the static file location
    rewrite /favicon.svg /static/favicon.svg
    rewrite /favicon.ico /static/favicon.svg

    # Route the GoAccess real-time WebSocket
    handle /ws-metrics* {
        reverse_proxy goaccess:7890
    }

    # Route all standard web traffic to FastAPI
    handle {
        reverse_proxy web:8000
    }
}
